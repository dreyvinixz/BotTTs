    "check": "node --check index.js && node -e \"const fs=require('fs'),path=require('path'),cp=require('child_process');function walk(d){for(const f of fs.readdirSync(d)){const p=path.join(d,f),s=fs.statSync(p);if(s.isDirectory())walk(p);else if(p.endsWith('.js'))cp.execFileSync(process.execPath,['--check',p],{stdio:'inherit'});}}walk('scripts');\"",
    "ollama:create": "ollama create botbanana -f local/ollama/Modelfile",
    "ollama:create:example": "ollama create botbanana -f examples/Modelfile.example",
    "test": "npm run check && node --test \"tests/**/*.test.js\"",
    "test:trivia": "node tools/test_trivia.js"
  },
