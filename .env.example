# Required
DISCORD_TOKEN=

# Local LLM
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=botbanana
OLLAMA_TIMEOUT_MS=30000
OLLAMA_NUM_PREDICT=120
OLLAMA_TEMPERATURE=0.6
OLLAMA_TOP_K=40
OLLAMA_TOP_P=0.9
OLLAMA_REPEAT_PENALTY=1.15

# Serious question mode
# local = Ollama only
# gemini_cli = Gemini CLI with local Ollama fallback
QUESTION_PROVIDER=local
GEMINI_CLI_MODEL=auto
GEMINI_CLI_TIMEOUT_MS=120000

# Stable Diffusion Forge
FORGE_HOST=http://127.0.0.1:7860
FORGE_REALISTIC_MODEL=DreamShaper_8_pruned.safetensors
FORGE_ANIME_MODEL=MeinaMix_V11.safetensors
FORGE_STEPS=25
FORGE_WIDTH=512
FORGE_HEIGHT=512
FORGE_SAMPLER=Euler a
FORGE_BATCH_SIZE=1
FORGE_REALISTIC_NEGATIVE_PROMPT=ugly, low quality, bad anatomy, deformed, watermark, text, extra fingers, mutated hands, poorly drawn, blurry, artifacts, cluttered background, messy composition
FORGE_ANIME_NEGATIVE_PROMPT=ugly, low quality, bad anatomy, deformed, poorly drawn face, poorly drawn hands, missing fingers, missing limbs, cluttered background, messy composition, watermark, text, blurry

# Text-to-speech
EDGE_TTS_VOICE=pt-BR-AntonioNeural
VOICE_IDLE_TIMEOUT_MS=300000
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_TTS_LANGUAGE_CODE=pt-BR
GOOGLE_TTS_VOICE=pt-BR-Wavenet-A

# Behavior tuning
CHANCE_RESPONDER_PERGUNTA=0.12
CHANCE_RESPONDER_CASUAL=0.003
CHANCE_RESPONDER_MIDIA=0.10
COOLDOWN_USUARIO_MS=120000
COOLDOWN_CANAL_MS=60000
CHAT_CACHE_LIMIT=100
CONTEXT_HISTORY_LIMIT=6
GIF_COOLDOWN_MS=180000
TEMP_ERROR_DELETE_MS=5000

# Runtime data
DATA_DIR=data
GIFS_PATH=data/gifs.json
FOFOCAS_PATH=data/fofocas.json
DEFAULT_GIF_URL=https://media.tenor.com/Z4cOQWc-DscAAAAC/banana.gif

# Optional long-memory server
SERVIDOR_FOFOCA=
FOFOCA_MIN_MESSAGES=50
FOFOCA_MAX_ITEMS=30

# Policy files
POLITICAS_PATH=politicas.txt
POLITICAS_IMAGEM_PATH=politicas_imagem.txt
